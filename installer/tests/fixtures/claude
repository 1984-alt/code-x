#!/usr/bin/env bash
# Fake `claude` CLI for offline installer tests (PBF-PROP-017).
# Understands just enough of `claude plugin ...` to exercise install.sh's
# marketplace/plugin logic without touching the real network or a real
# Claude Code install. State lives under $FAKE_CLAUDE_HOME.
set -u
STATE="${FAKE_CLAUDE_HOME:?FAKE_CLAUDE_HOME must be set}"
MARKETPLACES_DIR="$STATE/marketplaces"
INSTALLED_FILE="$STATE/installed.json"
mkdir -p "$MARKETPLACES_DIR"
[ -f "$INSTALLED_FILE" ] || echo "[]" > "$INSTALLED_FILE"

repo_name_from_source() {
  # Strip a trailing "#ref" pin and a ".git" suffix, then take the last path
  # segment. Accepts both the documented full-URL form
  # ("https://github.com/obra/superpowers.git#v6.1.1") and a bare
  # "owner/repo" shorthand (used by the negative tests to simulate an
  # unpinned add). -> "superpowers" / "code-x".
  local s="${1%%#*}"
  s="${s%.git}"
  basename "$s"
}

resolved_origin_url() {
  # $1 = the add source (with or without a "#ref" pin). Mirrors what the
  # real `claude` CLI + GitHub actually do: a full URL is used as-is (minus
  # the "#ref" pin); a bare "owner/repo" shorthand resolves against GitHub,
  # same as the real CLI's shorthand always does. This is what INV-2 reads
  # back via `git remote get-url origin` on the real checkout.
  local s="${1%%#*}"
  case "$s" in
    *://*) printf '%s' "$s" ;;
    *) printf 'https://github.com/%s.git' "$s" ;;
  esac
}

declared_marketplace_name() {
  # A real marketplace's NAME comes from its own marketplace.json `name`
  # field, which can differ from the repo name. RUNTIME-VERIFIED 2026-07-03:
  # obra/superpowers declares "superpowers-dev"; 1984-alt/code-x declares
  # "code-x". This mapping mirrors that reality so the fake CLI reports the
  # same names the real one does (install.sh looks marketplaces up by name).
  case "$(repo_name_from_source "$1")" in
    superpowers) echo "superpowers-dev" ;;
    *) repo_name_from_source "$1" ;;
  esac
}

cmd="${1:-}"; shift || true
sub="${1:-}"; shift || true

case "$cmd $sub" in
  "plugin marketplace")
    action="${1:-}"; shift || true
    case "$action" in
      add)
        source="${1:-}"
        echo "$source" >> "$STATE/marketplace_add_log"
        ref="${source#*#}"
        [ "$ref" = "$source" ] && ref=""
        mp_name="$(declared_marketplace_name "$source")"
        plugin_name="$(repo_name_from_source "$source")"
        dir="$MARKETPLACES_DIR/$mp_name"
        if [ ! -d "$dir/.git" ]; then
          # Fake CLI's stand-in for "clone this tag": self-declare the
          # requested ref (minus a leading "v") as the plugin's version in a
          # marketplace.json, mirroring what a real tagged release does. The
          # marketplace's own `name` may differ from the plugin name (as with
          # superpowers-dev). FAKE_CLAUDE_FORCE_VERSION overrides the version
          # for tests that simulate upstream drift (the tag's real content
          # declares a DIFFERENT version than what was requested).
          version="${FAKE_CLAUDE_FORCE_VERSION:-${ref#v}}"
          [ -z "$version" ] && version="0.0.0-notag"
          mkdir -p "$dir/.claude-plugin"
          printf '{"name": "%s", "plugins": [{"name": "%s", "version": "%s"}]}\n' \
            "$mp_name" "$plugin_name" "$version" \
            > "$dir/.claude-plugin/marketplace.json"
          git -C "$dir" init -q
          git -C "$dir" remote add origin "$(resolved_origin_url "$source")" >/dev/null 2>&1
          git -C "$dir" add -A
          # Fixed author/committer date (not "now"): a commit's sha is a hash
          # of its content INCLUDING these timestamps, so pinning them makes
          # this fake clone's resulting commit sha fully deterministic and
          # reproducible across separate invocations — the offline test
          # suite relies on predicting this sha (see predict_fake_commit_sha
          # in run-installer-tests.sh) to exercise INV-3's commit_sha pin
          # without needing a real upstream clone.
          GIT_AUTHOR_DATE="2026-01-01T00:00:00+00:00" \
          GIT_COMMITTER_DATE="2026-01-01T00:00:00+00:00" \
          git -C "$dir" -c user.email=test@test -c user.name=test commit -q -m "init $mp_name"
          # Mirror a real tag-pinned clone: HEAD sits exactly ON the tag, so
          # `git describe --exact-match --tags HEAD` returns it. A shorthand /
          # unpinned add carries no ref => no tag => the installer's exact-tag
          # check must fail closed (that is hole A/B being closed).
          [ -n "$ref" ] && git -C "$dir" tag "$ref" >/dev/null 2>&1
        fi
        exit 0
        ;;
      list)
        # Pretty-printed, and each entry carries a DECOY nested object
        # (`"aliases": {"name": "code-x"}`) — a REAL, valid, unescaped
        # `"name": "code-x"` substring that is NOT the entry's actual
        # top-level name. A real CLI is free to format its JSON however it
        # likes and add fields. This deliberately breaks any regression of
        # install.sh back to a grep-substring presence check
        # (`grep '"name": "code-x"'`), which would match the decoy and
        # mis-read presence — only a structured JSON read keyed on the
        # top-level `name` is correct. See
        # test_structured_read_not_fooled_by_decoy_substring.
        {
          printf '['
          first=1
          for d in "$MARKETPLACES_DIR"/*/; do
            [ -d "$d" ] || continue
            n="$(basename "$d")"
            [ "$first" -eq 1 ] || printf ','
            first=0
            printf '\n  {\n    "name": "%s",\n    "source": "github",\n    "installLocation": "%s",\n    "aliases": { "name": "code-x" }\n  }' "$n" "${d%/}"
          done
          printf '\n]\n'
        }
        ;;
      update)
        exit 0
        ;;
      remove)
        name="${1:-}"
        rm -rf "${MARKETPLACES_DIR:?}/$name"
        exit 0
        ;;
    esac
    ;;
  "plugin list")
    # Pretty-printed, with a DECOY entry whose `hint` value contains the
    # substring `"id": "code-x@code-x"` while its real `id` is "decoy". Same
    # purpose as the marketplace-list decoy above: a grep-substring regression
    # of install.sh's plugin_installed() would match the decoy and mis-read
    # the code-x plugin as installed; only a structured read keyed on `id` is
    # correct.
    python3 - "$INSTALLED_FILE" <<'EOF'
import json, sys
with open(sys.argv[1]) as f:
    data = json.load(f)
# Decoy entry: a REAL, valid, unescaped `"id": "code-x@code-x"` substring
# nested under `aliases`, on an entry whose actual top-level id is "decoy".
data = [{"id": "decoy", "aliases": {"id": "code-x@code-x"}}] + data
print(json.dumps(data, indent=2))
EOF
    ;;
  "plugin install")
    id="${1:-}"
    # FAKE_CLAUDE_FAIL_INSTALL lets a test simulate a plugin install that
    # fails for a specific id (e.g. a flaky registry) — used to prove INV-5's
    # chain-halt: a soft-failed code-x install must stop before superpowers.
    if [ -n "${FAKE_CLAUDE_FAIL_INSTALL:-}" ] && [ "$id" = "$FAKE_CLAUDE_FAIL_INSTALL" ]; then
      echo "fake-claude: simulated install failure for $id" >&2
      exit 1
    fi
    tmp="$(mktemp)"
    python3 - "$INSTALLED_FILE" "$id" > "$tmp" <<'EOF'
import json, sys
path, plugin_id = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = json.load(f)
if not any(p.get("id") == plugin_id for p in data):
    data.append({"id": plugin_id, "version": "0.0.0-test"})
print(json.dumps(data))
EOF
    mv "$tmp" "$INSTALLED_FILE"
    exit 0
    ;;
  "plugin details")
    echo "version: 0.0.0-test"
    ;;
  *)
    echo "fake-claude: unhandled command: $cmd $sub $*" >&2
    exit 1
    ;;
esac
